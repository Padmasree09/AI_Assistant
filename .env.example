# FastAPI
APP_HOST=127.0.0.1
APP_PORT=8000

# llama.cpp server
LLAMA_URL=http://localhost:8080/completion
LLAMA_TIMEOUT_SECONDS=120
AGENT_MAX_TOKENS=192
PLANNER_MAX_TOKENS=96
SYNTHESIS_MAX_TOKENS=256
CRITIQUE_MAX_TOKENS=96
USE_LLM_PLANNER=false
ENABLE_CRITIC=false

# Retriever
RETRIEVER_MODE=local

# Qdrant
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_COLLECTION=knowledge_base
QDRANT_LOCAL_PATH=data/qdrant

# Embeddings
EMBEDDING_BACKEND=hash
EMBEDDING_MODEL_NAME=BAAI/bge-small-en-v1.5
EMBEDDING_SIZE=384

# Optional helper values for the Windows startup scripts
LLAMA_SERVER_EXE=C:\Users\Tadi.Padmasree\ai-projects\llama.cpp\bin\llama-server.exe
LLAMA_MODEL_PATH=C:\Users\Tadi.Padmasree\ai-projects\models\phi-3.gguf
